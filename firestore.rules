// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() { return request.auth != null; }
    function role() { return request.auth.token.role; }
    function isAdmin() { return isSignedIn() && role() == 'ADMIN'; }
    function isSupervisor() { return isSignedIn() && role() == 'SUPERVISOR'; }
    function isStaff() { return isAdmin() || isSupervisor(); }
    function isSelf(uid) { return isSignedIn() && request.auth.uid == uid; }

    // All break-state mutations happen exclusively through Cloud Functions
    // (Admin SDK). That's deliberate: the concurrency-limit + FIFO-queue
    // logic needs atomic multi-document transactions, which rules can't
    // express safely. Rules here only gate READS, plus a couple of
    // low-stakes self-writes (presence).

    match /users/{uid} {
  allow read, write: if true; 
    }
    match /shift_sessions/{id} {
      allow read: if isStaff() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }
    match /break_sessions/{id} {
      allow read: if isStaff() || (isSignedIn() && resource.data.uid == request.auth.uid);
      allow write: if false;
    }
    match /break_aggregates/{id} {
      allow read: if isStaff();
      allow write: if false;
    }
    match /break_settings/{id} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    match /counters/{id} {
      allow read, write: if false;
    }
    match /presence/{uid} {
      allow read: if isSignedIn();
      // role spoof-proofed: client can only write the role it already has
      // on its trusted users/ doc.
      allow create, update: if isSelf(uid)
        && request.resource.data.role == get(/databases/$(database)/documents/users/$(uid)).data.role;
      allow delete: if false;
    }
  }
}